# Copy this file to .env and fill in the two required values.

# Required — create a bot with @BotFather on Telegram, it gives you this token.
TELEGRAM_TOKEN=

# Required — from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — set BOTH to persist users, orders, reviews and chat history to
# Supabase. Leave them empty and the bot uses in-memory storage instead, which
# is fine for running the demo (data is lost on restart).
SUPABASE_URL=
SUPABASE_KEY=
